# Copy this file to .env and fill in the values
# =============================================================================
# Database (Dokploy-managed PostgreSQL — use Internal Credentials)
# =============================================================================
DATABASE_HOST=your-postgres-host
DATABASE_NAME=erp_gpack
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# =============================================================================
# Security
# =============================================================================
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
SHARE_TOKEN_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_HEX_STRING

# =============================================================================
# CORS Origin — Your production domain
# =============================================================================
CORS_ORIGIN=https://erp.Gpacksa.com

# =============================================================================
# Node Environment
# =============================================================================
NODE_ENV=production

# =============================================================================
# AI Assistant (OpenAI-compatible — supports any provider)
# =============================================================================
# API key from your provider
OPENAI_API_KEY=your_api_key_here

# Model name (depends on your provider)
OPENAI_MODEL=gpt-4o-mini

# Base URL — change this to use a different provider:
#   OpenAI:      https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Groq:        https://api.groq.com/openai/v1
#   Together AI: https://api.together.xyz/v1
#   Azure OpenAI: https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Enable/disable AI assistant
AI_ASSISTANT_ENABLED=true
